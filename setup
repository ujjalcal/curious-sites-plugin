#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BIN_DIR="$SCRIPT_DIR/bin"

echo "CuriousCirkits Portfolio Plugin"
echo "================================"
echo ""

# Check dependencies
for cmd in curl jq; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is required but not installed." >&2
    exit 1
  fi
done

# Make CLI executable
chmod +x "$BIN_DIR/cc"

# Symlink cc into a directory on PATH
LINK_TARGET="/usr/local/bin/cc"
if [[ -L "$LINK_TARGET" || -e "$LINK_TARGET" ]]; then
  echo "Note: $LINK_TARGET already exists, skipping symlink."
  echo "  The CLI is available at: $BIN_DIR/cc"
else
  if ln -sf "$BIN_DIR/cc" "$LINK_TARGET" 2>/dev/null; then
    echo "Linked cc → $LINK_TARGET"
  else
    # Fall back to ~/bin if /usr/local/bin needs sudo
    mkdir -p "$HOME/bin"
    ln -sf "$BIN_DIR/cc" "$HOME/bin/cc"
    echo "Linked cc → $HOME/bin/cc"
    if [[ ":$PATH:" != *":$HOME/bin:"* ]]; then
      echo ""
      echo "Add to your shell profile:"
      echo "  export PATH=\"\$HOME/bin:\$PATH\""
    fi
  fi
fi

echo ""
echo "Setup complete."
echo ""
echo "Next: run 'cc auth setup' to connect your account."
