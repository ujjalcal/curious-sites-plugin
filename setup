#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
BIN_DIR="$SCRIPT_DIR/bin"

echo "CuriousCirkits Portfolio Plugin"
echo "================================"
echo ""

# Check dependencies
for cmd in curl jq; do
  if ! command -v "$cmd" &>/dev/null; then
    echo "Error: $cmd is required but not installed." >&2
    exit 1
  fi
done

# Make executables
chmod +x "$BIN_DIR/csites" "$BIN_DIR/uninstall"

# Symlink csites into a directory on PATH
LINKED=false
LINK_TARGET="/usr/local/bin/csites"
if [[ -L "$LINK_TARGET" || -e "$LINK_TARGET" ]]; then
  echo "Note: $LINK_TARGET already exists, skipping symlink."
  LINKED=true
else
  if ln -sf "$BIN_DIR/csites" "$LINK_TARGET" 2>/dev/null; then
    echo "Linked csites → $LINK_TARGET"
    LINKED=true
  else
    # Fall back to ~/bin if /usr/local/bin needs sudo
    mkdir -p "$HOME/bin"
    ln -sf "$BIN_DIR/csites" "$HOME/bin/csites"
    echo "Linked csites → $HOME/bin/csites"
    LINKED=true

    # Auto-add ~/bin to PATH in shell profile
    if [[ ":$PATH:" != *":$HOME/bin:"* ]]; then
      SHELL_RC=""
      if [[ -f "$HOME/.zshrc" ]]; then
        SHELL_RC="$HOME/.zshrc"
      elif [[ -f "$HOME/.bashrc" ]]; then
        SHELL_RC="$HOME/.bashrc"
      elif [[ -f "$HOME/.bash_profile" ]]; then
        SHELL_RC="$HOME/.bash_profile"
      fi
      if [[ -n "$SHELL_RC" ]]; then
        # Check if we already added it
        if ! grep -q '# CuriousCirkits' "$SHELL_RC" 2>/dev/null; then
          echo '' >> "$SHELL_RC"
          echo '# CuriousCirkits' >> "$SHELL_RC"
          echo 'export PATH="$HOME/bin:$PATH"' >> "$SHELL_RC"
          echo "Added PATH to $SHELL_RC (takes effect in new terminals)"
        fi
      fi
    fi
  fi
fi

# Add to project CLAUDE.md if a project dir was passed
ORIGINAL_DIR="${CSITES_PROJECT_DIR:-}"
if [[ -n "$ORIGINAL_DIR" ]] && [[ -d "$ORIGINAL_DIR/.git" || -f "$ORIGINAL_DIR/CLAUDE.md" ]]; then
  (cd "$ORIGINAL_DIR" && "$BIN_DIR/csites" init)
fi

echo ""
echo "Setup complete."

# Run auth setup using the full path (not the symlink, which may not
# be on PATH in this shell session)
echo ""
if [[ -f "$HOME/.curiouscirkits/api-key" ]] || [[ -n "${CC_API_KEY:-}" ]]; then
  echo "Already authenticated."
  "$BIN_DIR/csites" auth status
else
  echo "Connecting your account..."
  echo ""
  "$BIN_DIR/csites" auth setup
fi

# Final instructions — only if ~/bin isn't on PATH in this session
echo ""
if ! command -v csites &>/dev/null; then
  echo "To use csites in this terminal, run:"
  echo "  source ~/.zshrc"
  echo ""
  echo "Or use the full path:"
  echo "  $BIN_DIR/csites"
  echo ""
  echo "New terminals will have csites on PATH automatically."
else
  echo "Ready. Run 'csites help' to see available commands."
fi
